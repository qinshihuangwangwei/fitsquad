# ── 数据库 (Supabase PostgreSQL) ──
# 从 Supabase 项目 Settings > Database > Connection string > URI 获取
# 格式: postgresql://postgres.[项目ID]:[密码]@aws-0-[区域].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://..."

# ── 本地开发用 SQLite ──
# DATABASE_URL="file:./dev.db"

# ── NextAuth ──
# 生产环境
# NEXTAUTH_URL="https://fitsquad-kappa.vercel.app"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here-at-least-32-chars"

# ── 生产环境 ──
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_SECRET="your-production-secret"
